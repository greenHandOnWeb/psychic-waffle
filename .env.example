# Supabase（非 Mock 时必填）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 设为 true 时使用本地 Mock 客户端（localStorage + 延迟模拟），无需真实 Supabase
# 站内「设置」页可覆盖为强制 Mock / 强制远端 / 跟随本项（存本机 localStorage）
VITE_SUPABASE_MOCK=true

# 可选：表情包「联网搜索」使用 Pixabay API（免费申请：https://pixabay.com/api/docs/）
# 也可在站内「设置」页填写（存本机，优先于下方 .env）
# VITE_PIXABAY_API_KEY=

# 可选：覆盖默认模板目录（默认已使用站点内 public/templates-catalog.json → /templates-catalog.json）
# 也可在站内「设置」页填写 URL（优先于本变量）
# 外链须 HTTPS + CORS，格式同 public/templates-catalog.json
# VITE_TEMPLATES_CATALOG_URL=https://cdn.jsdelivr.net/gh/你的用户/你的仓库@main/path/catalog.json
